# Copy this file to .env and fill in your Supabase project credentials.
# Never commit .env to version control.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Google Books API key to avoid public quota limits.
# Create one at https://console.cloud.google.com/ (Books API).
# Without a key the public endpoint is used (limited quota).
EXPO_PUBLIC_GOOGLE_BOOKS_API_KEY=
