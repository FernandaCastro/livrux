{
  "expo": {
    "name": "Livrux",
    "slug": "livrux",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/livrux.png",
    "userInterfaceStyle": "light",
    "scheme": "livrux",
    "splash": {
      "image": "./assets/livrux.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.livrux.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/livrux.png",
        "backgroundColor": "#F5A623"
      },
      "package": "com.livrux.app",
      "edgeToEdgeEnabled": true,
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "kotlinVersion": "2.0.21",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/livrux.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Livrux to use your camera to scan book barcodes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Livrux to access your photos to set profile and book cover images.",
          "cameraPermission": "Allow Livrux to use your camera to take profile and book cover photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2817e5d9-beed-4a88-a77c-144a43a09443"
      }
    },
    "owner": "fcastrorj"
  }
}
