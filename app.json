{
  "expo": {
    "name": "Livrux",
    "slug": "livrux",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/livrux.png",
    "userInterfaceStyle": "light",
    "scheme": "livrux",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.livrux.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5A623"
      },
      "package": "com.livrux.app",
      "edgeToEdgeEnabled": true,
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "kotlinVersion": "2.0.21",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAFAF7",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Livrux to use your camera to scan book barcodes.",
          "microphonePermission": "Allow Livrux to access your microphone."
        }
      ],
      "expo-localization",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2817e5d9-beed-4a88-a77c-144a43a09443"
      }
    },
    "owner": "fcastrorj"
  }
}
